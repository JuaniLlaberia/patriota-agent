# patriota-tools — the El Patriota MCP tool server (news ingestion, editorial
# state, CMS publishing). Runs as a stdio MCP server that Hermes Agent launches
# as a subprocess, OR standalone for local testing.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Copy project metadata + source, then install. (The build backend needs the
# package directory present, so we can't install from pyproject.toml alone.)
COPY pyproject.toml ./
COPY patriota_tools ./patriota_tools
COPY config ./config
COPY fixtures ./fixtures
RUN pip install --no-cache-dir .

# Non-root. Pre-create /data owned by `patriota` so the named volume mounted
# there inherits writable ownership on first creation.
RUN useradd --create-home patriota \
    && mkdir -p /data \
    && chown -R patriota /app /data
USER patriota

# Default: run the MCP server over stdio.
CMD ["patriota-tools"]
