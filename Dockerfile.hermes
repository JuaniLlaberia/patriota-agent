# B2 only — Hermes runtime + the patriota-tools MCP server installed in an
# ISOLATED venv, so Hermes can launch it over stdio without polluting Hermes'
# own Python environment.
#
# IMPORTANT: do NOT install into Hermes' venv (/opt/hermes/.venv) — our `mcp`
# dependency clobbers Hermes' `mcp[cli]` and breaks the `hermes mcp` command.
# We use a separate venv at /opt/patriota/venv. MCP command:
#   /opt/patriota/venv/bin/patriota-tools
#
# (Verified against nousresearch/hermes-agent:latest — Node-based, system
# python3 at /usr/bin/python3 with a working `venv` module.)
FROM nousresearch/hermes-agent:latest

USER root
COPY pyproject.toml /opt/patriota/pyproject.toml
COPY patriota_tools /opt/patriota/patriota_tools
COPY config /opt/patriota/config
COPY fixtures /opt/patriota/fixtures
COPY hermes/prompts /opt/patriota/prompts
COPY hermes/scripts/start-gateway.sh /opt/patriota/start-gateway.sh
RUN chmod +x /opt/patriota/start-gateway.sh \
    && /usr/bin/python3 -m venv /opt/patriota/venv \
    && /opt/patriota/venv/bin/pip install --no-cache-dir /opt/patriota
